    "# Create a table for storing documents with their embeddings\n",
    "\n",
    "conn.execute(\"\"\"\n",
    "    DROP TABLE IF EXISTS documents\n",
    "\"\"\")\n",
    "\n",
    "conn.execute(\"\"\"\n",
    "    CREATE TABLE documents (\n",
    "        id SERIAL PRIMARY KEY,\n",
    "        course TEXT,\n",
    "        section TEXT,\n",
    "        question TEXT,\n",
    "        answer TEXT,\n",
    "        embedding vector(384)\n",
    "    )\n",
    "\"\"\")"
   ]
